# Plantilla. Copia a `secrets.toml` (git-ignored) y úsala tal cual.
# El dashboard usa factory_reader (SELECT-only) — garantía a nivel DB
# que el front NO puede escribir aunque el código intentara.
# Las skills (Claude Code) sí usan el user 'factory' con permisos plenos.
[connections.factory]
dialect = "postgresql"
host = "localhost"
port = 5433
database = "factory"
username = "factory_reader"
password = "factory_reader_local"
